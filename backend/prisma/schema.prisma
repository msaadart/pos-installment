// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Users & Auth ---

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(SALES_USER)
  shopId    Int?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  purchases Purchase[] // User who created purchase
}

enum Role {
  SUPER_ADMIN
  SHOP_ADMIN
  SALES_USER
}

// --- Shop Management ---

model Shop {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  contact   String?
  isActive  Boolean  @default(true)
  users     User[]
  products  Product[]
  sales     Sale[]
  purchases Purchase[]
  customers Customer[] // Customers might be shop-specific or global
  expenses  Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Products & Inventory ---

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String   @unique
  barcode     String?
  description String?
  price       Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5) // Low stock alert
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id])
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     Int?
  brand       Brand?   @relation(fields: [brandId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
  imageUrl    String?
  saleItems   SaleItem[]
  purchaseItems PurchaseItem[]
  
  @@unique([sku, shopId]) // SKU unique per shop? Or global? Ideally unique per shop but simplifying to global SKU for now if constraint allows, or composite
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  shopId    Int?      // Null for global categories
  isActive  Boolean   @default(true)
  products  Product[]
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  isActive  Boolean   @default(true)
  products  Product[]
}

// --- Customers & Suppliers ---

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  address   String?
  cnic      String?  // National ID
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  creditLimit Decimal @default(0) @db.Decimal(10, 2)
  shopId    Int?     // Nullable means global customer? Or specific? Let's make it linked to a shop initially, but usually customers are global in multi-shop chains.
  shop      Shop?    @relation(fields: [shopId], references: [id])
  sales     Sale[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  company   String?
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  purchases Purchase[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// --- Sales & POS ---

model Sale {
  id          Int      @id @default(autoincrement())
  invoiceNo   String   @unique
  totalAmount Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  netAmount   Decimal  @db.Decimal(10, 2)
  paidAmount  Decimal  @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2)
  status      SaleStatus @default(COMPLETED)
  paymentMethod PaymentMethod @default(CASH)
  saleType    SaleType @default(CASH) // CASH, CREDIT, INSTALLMENT
  
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  
  items       SaleItem[]
  installmentPlan InstallmentPlan?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  MIXED
}

enum SaleType {
  CASH
  CREDIT
  INSTALLMENT
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
}

// --- Installments ---

model InstallmentPlan {
  id              Int      @id @default(autoincrement())
  saleId          Int      @unique
  sale            Sale     @relation(fields: [saleId], references: [id])
  
  totalAmount     Decimal  @db.Decimal(10, 2) 
  downPayment     Decimal  @db.Decimal(10, 2)
  monthlyInstallment Decimal @db.Decimal(10, 2)
  totalInstallments Int
  interestRate    Decimal  @default(0) @db.Decimal(5, 2)
  startDate       DateTime
  endDate         DateTime?
  status          PlanStatus @default(ACTIVE)
  
  installments    Installment[]
  createdAt       DateTime @default(now())
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

model Installment {
  id              Int      @id @default(autoincrement())
  planId          Int
  plan            InstallmentPlan @relation(fields: [planId], references: [id])
  
  dueDate         DateTime
  amount          Decimal  @db.Decimal(10, 2)
  paidAmount      Decimal  @default(0) @db.Decimal(10, 2)
  status          InstallmentStatus @default(PENDING)
  paidAt          DateTime?
  penalty         Decimal  @default(0) @db.Decimal(10, 2)
  notes           String?
  paymentMethod   PaymentMethod? @default(CASH)
  referenceId     String?
  
  createdAt       DateTime @default(now())
}

enum InstallmentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
}

// --- Purchases ---

model Purchase {
  id          Int      @id @default(autoincrement())
  invoiceNo   String?
  supplierId  Int
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  
  totalAmount Decimal  @db.Decimal(10, 2)
  paidAmount  Decimal  @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2)
  status      PurchaseStatus @default(COMPLETED)
  
  items       PurchaseItem[]
  createdAt   DateTime @default(now())
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  purchase    Purchase @relation(fields: [purchaseId], references: [id])
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
}

// --- Accounting ---

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String?  // e.g. Rent, Electricity
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id])
  date        DateTime @default(now())
  userId      Int?
}
